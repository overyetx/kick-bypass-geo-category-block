{
  "manifest_version": 3,
  "name": "Kick Bypass Geo-Category Block",
  "version": "1.0.0",
  "author": "overyetx",
  "description": "Bypass Kick.com geo-restrictions for livestreams",
  "permissions": [],
  "host_permissions": [
    "*://*.kick.com/*",
    "*://kick.com/*"
  ],
  "content_scripts": [
    {
      "matches": [
        "*://*.kick.com/*",
        "*://kick.com/*"
      ],
      "js": ["inject.js"],
      "run_at": "document_start",
      "world": "MAIN"
    }
  ],
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}
